rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.get('email', '') == "rjjisan744@gmail.com" ||
          (
            (request.auth.token.get('email', '') == "rjjisan744@innerpower.app" || request.auth.token.get('email', '') == "admin@innerpower.app") && 
            request.auth.token.get('email_verified', false) == true
          )
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'role', 'status']) &&
             data.username is string && data.username.size() > 0 &&
             data.role in ['user', 'admin'] &&
             data.status in ['pending', 'active', 'blocked'];
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidReferral(data) {
      return hasOnlyAllowedFields(['referrer_id', 'referrer_username', 'referee_id', 'referee_username', 'bonus_granted', 'created_at']) &&
             data.referrer_id is string && data.referrer_id.size() > 0 &&
             data.referrer_username is string && data.referrer_username.size() > 0 &&
             data.referee_id is string && data.referee_id.size() > 0 &&
             data.referee_username is string && data.referee_username.size() > 0 &&
             data.bonus_granted is bool;
    }

    function isImmutable(field) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([field]);
    }

    // ===============================================================
    // Rules for Collections
    // ===============================================================

    match /users/{userId} {
      allow list: if isAdmin() || (
        isAuthenticated() && 
        request.query.limit == 1 && 
        request.query.filters.keys().hasOnly(['referral_code'])
      );
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAdmin() || (
                      isOwner(userId) && 
                      // Protect critical fields from being changed by the owner
                      isImmutable('status') &&
                      isImmutable('is_paid') &&
                      isImmutable('has_pending_subscription') &&
                      // Allow setting referred_by and trial_ends_at ONLY ONCE (when referred_by is null)
                      (
                        (resource.data.referred_by == null && request.resource.data.referred_by != null) ||
                        (isImmutable('referred_by') && isImmutable('trial_ends_at'))
                      ) &&
                      // Allow demotion to user, but block unauthorized promotion to admin
                      (request.resource.data.role == resource.data.role || request.resource.data.role == 'user')
                    ) || (
                      // Allow incrementing referral_count by others (during registration)
                      isAuthenticated() && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['referral_count']) &&
                      request.resource.data.referral_count == resource.data.referral_count + 1
                    );
      allow delete: if isAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /user_notes/{noteId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
    }

    match /subscriptions/{subId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /categories/{catId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    match /books/{bookId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
    }

    match /notifications/{notifId} {
      allow list: if isAuthenticated();
      allow read: if isAuthenticated() && (
        resource.data.get('user_id', null) == null || 
        resource.data.user_id == request.auth.uid || 
        isAdmin()
      );
      allow write: if isAdmin();
    }

    match /notification_replies/{replyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /support_messages/{msgId} {
      allow read: if isAdmin() || 
                     (isAuthenticated() && resource.data.user_id == request.auth.uid) ||
                     (resource.data.user_id is string && resource.data.user_id.matches("^web-.*"));
      allow create: if isAuthenticated() || 
                       (request.resource.data.user_id is string && request.resource.data.user_id.matches("^web-.*"));
      allow update: if isAdmin() || (
        (isAuthenticated() && resource.data.user_id == request.auth.uid) ||
        (resource.data.user_id is string && resource.data.user_id.matches("^web-.*"))
      );
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /referrals/{referralId} {
      allow read: if isAuthenticated() && (resource.data.referrer_id == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidReferral(request.resource.data) && (request.resource.data.referee_id == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /referral_codes/{code} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /device_ids/{deviceId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /reading_history/{historyId} {
      allow list: if isAdmin();
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    match /wishlist/{wishId} {
      allow list: if isAdmin();
      allow read: if isAuthenticated() && (
        wishId.startsWith(request.auth.uid) || 
        (resource != null && resource.data.user_id == request.auth.uid) || 
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && (
        wishId.startsWith(request.auth.uid) || 
        (resource != null && resource.data.user_id == request.auth.uid) || 
        isAdmin()
      );
    }
  }
}
